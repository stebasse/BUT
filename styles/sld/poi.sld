              <se:ExternalGraphic>
                <se:OnlineResource xlink:href="C:/OSGeo4W/apps/qgis/svg/accommodation/accommodation_house.svg?fill=%2303a600&amp;fill-opacity=1&amp;outline=%23232323&amp;outline-opacity=1&amp;outline-width=0" xlink:type="simple"/>
                <se:Format>image/svg+xml</se:Format>
              </se:ExternalGraphic>
              <!--Plain SVG fallback, no parameters-->
              <se:ExternalGraphic>
                <se:OnlineResource xlink:href="accommodation/accommodation_house.svg" xlink:type="simple"/>
                <se:Format>image/svg+xml</se:Format>
